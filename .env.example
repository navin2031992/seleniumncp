# Selenium MCP Automation — Environment Variables
# Copy this file to .env and fill in your values. Never commit .env to git.

# Test environment (dev | staging | prod)
TEST_ENV=dev

# Jira Integration
JIRA_BASE_URL=https://your-org.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token-here

# Selenium Configuration
# Edge is the default (system-installed on Windows).
# Switch to chrome or firefox if needed.
SELENIUM_BROWSER=edge
SELENIUM_HEADLESS=false

# Optional: CI webhook for pipeline results
WEBHOOK_URL=
